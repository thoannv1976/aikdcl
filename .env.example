# =============================================================================
# AIKDCL — biến môi trường cho local development.
# Copy file này thành `.env.local` rồi điền giá trị thật.
# .env.local KHÔNG commit (đã có trong .gitignore).
# Trên production, các secret được nạp qua Secret Manager (xem apphosting.yaml).
# =============================================================================

# ----- Anthropic Claude (server-side ONLY, không bao giờ NEXT_PUBLIC_) -----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- Firebase project (public config — copy từ Firebase Console -> Project settings) -----
NEXT_PUBLIC_FIREBASE_PROJECT_ID=aikdcl
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=aikdcl.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=aikdcl.appspot.com
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1056300284274
NEXT_PUBLIC_FIREBASE_APP_ID=1:1056300284274:web:...
NEXT_PUBLIC_APP_NAME=AIKDCL

# Optional: App Check reCAPTCHA v3 site key
# NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# ----- Firebase Admin (server-side) -----
# Paste nguyên file service account JSON dưới dạng 1 dòng. Trên production,
# App Hosting tự inject ADC, không cần biến này.
FIREBASE_PROJECT_ID=aikdcl
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ----- Rate limit (override nếu cần, default 5/giờ + 30/ngày) -----
# RATE_LIMIT_PER_HOUR=10
# RATE_LIMIT_PER_DAY=60
